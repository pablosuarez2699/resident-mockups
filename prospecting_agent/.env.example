# ── Lead source ──────────────────────────────────────────────────────────────
# "google" = free path (Google Places + Hunter domain-search + web scraping)
# "apollo" = original Apollo.io path (personal use / when subscribed)
LEAD_SOURCE=google

# ── Google Places API (free path) ────────────────────────────────────────────
# Get a free key at: console.cloud.google.com → APIs & Services → Credentials
# Enable "Places API (New)" — $200/mo free credit resets monthly (~$2/run at
# this volume, so effectively always free).
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Hunter.io ────────────────────────────────────────────────────────────────
# Used for domain-search (find contacts by company domain) on the Google path,
# and email-finder on the Apollo-paid path.
# Free tier: 25 domain-search lookups/month. Paid ($34/mo): 500 lookups/month.
HUNTER_API_KEY=your_hunter_api_key_here
HUNTER_DOMAIN_SEARCH_BUDGET=25

# ── Anthropic (Claude qualification) ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Run parameters ────────────────────────────────────────────────────────────
TARGET_LEADS=100
HUNTER_BUDGET_PER_RUN=50
APOLLO_PAGES_PER_SECTOR=5

# ── Apollo.io (optional — set LEAD_SOURCE=apollo to use) ─────────────────────
APOLLO_API_KEY=your_apollo_api_key_here
APOLLO_PLAN=free
