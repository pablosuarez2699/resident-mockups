# ── Composition mode ──────────────────────────────────────────────────────────
# "llm"      = Claude composes each email (best tailoring; needs ANTHROPIC_API_KEY)
# "template" = deterministic, zero-cost templates only (free fallback)
# The llm path auto-falls back to templates if no key is present.
COMPOSE_MODE=llm

# ── Anthropic (Claude email composition) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Lead source ──────────────────────────────────────────────────────────────
# "excel" = read a .xlsx of leads (default; e.g. the prospecting agent's report)
# "csv"   = read a .csv of leads
# "manual"= build a single lead from CLI flags (no file)
LEAD_SOURCE=excel
# Optional default input file (CLI --input overrides this)
INPUT_FILE=

# ── Rep identity (appears in every signature / contact block) ────────────────
REP_NAME=Your Name
REP_TITLE=Account Executive, Purolator
REP_PHONE=(000) 000-0000
REP_EMAIL=you@purolator.com
# Optional scheduling link (Calendly, etc.) — leave blank to omit
REP_BOOKING_LINK=

# ── Tuning ────────────────────────────────────────────────────────────────────
# Minimum seconds between Claude API calls during batch composition
ANTHROPIC_MIN_SPACING_S=0.5
# Output directory for drafts (relative to outreach_agent/)
OUTPUT_DIR=drafts
